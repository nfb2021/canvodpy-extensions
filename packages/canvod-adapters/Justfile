_default:
    @just --list --unsorted

check:
    uv run ruff check . --fix
    uv run ruff format .
    uv run ty check

test:
    uv run pytest

clean:
    rm -fr build/ dist/ .eggs/
    find . -name '*.egg-info' -exec rm -fr {} +
    find . -name '__pycache__' -exec rm -fr {} +

hooks:
    uvx pre-commit install

sync:
    uv sync

build:
    uv build
